# ── GRAILS ENVIRONMENT VARIABLES ──────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ── SUPABASE (choose one backend or use both) ──────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── AIRTABLE ───────────────────────────────────────────────────────────────
# Get token from: https://airtable.com/create/tokens
# Base ID: open your base in browser → the ID in URL after /app
AIRTABLE_API_KEY=your-airtable-personal-access-token
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_NAME=Waitlist

# ── OPTIONAL ───────────────────────────────────────────────────────────────
# Leave blank if not using — the API handles missing vars gracefully
